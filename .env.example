# Copie para .env e ajuste os valores.
# cp .env.example .env

# PostgreSQL (obrigatório para Prisma)
# Com docker-compose.yml na raiz (defaults: user midgard, password midgard123, db midgard_db):
# DATABASE_URL="postgresql://midgard:midgard123@localhost:5432/midgard_db?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/midgard_db?schema=public"

# JWT — obrigatório em produção (não use o default do código)
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# API HTTP (opcional)
PORT=3000

# Catálogo / sync — API Nexustoons (HTTP; sem scrap HTML no MVP)
EXTERNAL_MANGA_BASE_URL="https://nexustoons.com"
# Opcional se a API passar a exigir chave:
# EXTERNAL_MANGA_API_KEY=

# Redis — progresso do sync capítulo a capítulo (chave midgard:manga-sync:v1:{manga|manhwa|manhua}:{slug})
# Sem REDIS_URL o sync continua funcionando; só não grava progresso no Redis.
REDIS_URL="redis://localhost:6379"
# Prazo máximo para percorrer todos os caps (ms). Padrão: 3 horas.
MANGA_SYNC_DEADLINE_MS=10800000
# Pausa entre um cap e outro (ms). Padrão: 300.
MANGA_SYNC_CHAPTER_DELAY_MS=300
# TTL do JSON de progresso no Redis (s). Padrão: 7 dias.
MANGA_SYNC_REDIS_TTL_SEC=604800

# Catálogo — faixa grátis (fração dos capítulos publicados, do 1º em ordem de number → public; restante coin)
# Aplicado ao fim de cada sync e pelo script `npm run db:apply-free-tier`. Padrão: 0.1 (~10%).
# MANGA_FREE_CHAPTER_FRACTION=0.1
# Custo em coins nos capítulos coin (MVP). Padrão: 1.
# MANGA_COIN_CHAPTER_COST=1
