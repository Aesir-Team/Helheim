# Copie para .env e ajuste os valores.
# cp .env.example .env

# PostgreSQL (obrigatório para Prisma)
# Com docker-compose.yml na raiz (defaults: user midgard, password midgard123, db midgard_db):
# DATABASE_URL="postgresql://midgard:midgard123@localhost:5432/midgard_db?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/midgard_db?schema=public"

# JWT — obrigatório em produção (não use o default do código)
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# API HTTP (opcional)
PORT=3000

# Catálogo / sync — API Nexustoons (HTTP; sem scrap HTML no MVP)
EXTERNAL_MANGA_BASE_URL="https://nexustoons.com"
# Opcional se a API passar a exigir chave:
# EXTERNAL_MANGA_API_KEY=
